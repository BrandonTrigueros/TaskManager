# ─── Network (Tailscale) ──────────────────────────────────────
HUB_IP=100.x.x.x
DB_HOST=${HUB_IP}
DB_PORT=5432

# ─── PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=heartbeat
POSTGRES_USER=hb_admin
POSTGRES_PASSWORD=CHANGE_ME_secure_password_here

# ─── Database DSN (used by all Python tools) ─────────────────
DB_DSN=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${DB_HOST}:${DB_PORT}/${POSTGRES_DB}

# ─── AI — Gemini (classification + OCR) ──────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash-lite

# ─── Telegram ─────────────────────────────────────────────────
TASKS_BOT_TOKEN=your_tasks_bot_token
ALLOWED_USER_ID=your_telegram_user_id
